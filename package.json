{
  "name": "ai-sdk-wire-middleware",
  "version": "0.1.2",
  "description": "Compact-syntax tool-call middleware for the Vercel AI SDK v6 — drop tool-call output tokens by 5–10× with a <call>tool key=value</call> wire format.",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "bench": "bun run bench/eval.ts",
    "bench:live": "bun run bench/live.ts"
  },
  "keywords": [
    "ai-sdk",
    "vercel-ai",
    "tool-calling",
    "middleware",
    "tokens",
    "llm",
    "wire-format"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thegreataxios/ai-sdk-wire-middleware.git"
  },
  "bugs": {
    "url": "https://github.com/thegreataxios/ai-sdk-wire-middleware/issues"
  },
  "homepage": "https://github.com/thegreataxios/ai-sdk-wire-middleware#readme",
  "contributors": [
    "Sawyer Cutler <sawyer@dirtroad.dev>",
    "Anthony Holley"
  ],
  "peerDependencies": {
    "ai": "^6.0.0",
    "@ai-sdk/provider": "^3.0.0",
    "zod": "^3.0.0 || ^4.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "ai": "^6.0.173",
    "@ai-sdk/provider": "^3.0.10",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "zod": "^4.4.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@ai-sdk/openai": "3.0.58",
    "js-tiktoken": "^1.0.21"
  }
}
