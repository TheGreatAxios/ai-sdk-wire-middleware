# === OpenRouter (used for LLM judge + optionally for model-under-test) ===
OPENROUTER_API_KEY=sk-or-v1-...

# Override the default free model.  Other free options:
#   minimax/minimax-m2.5:free               (default)
#   meta-llama/llama-3.3-70b-instruct:free  (strong instruction following)
#   deepseek/deepseek-chat-v3.1:free
#   qwen/qwen3-coder:free
#   google/gemini-2.0-flash-exp:free
# OPENROUTER_MODEL=minimax/minimax-m2.5:free

# === OpenAI-compatible provider (e.g. Z.AI, Together, Fireworks, Groq) ===
# When set, the benchmark uses this endpoint for the model-under-test
# instead of routing through OpenRouter.  Useful when you have credits
# on a provider but no OpenRouter key, or want to test a specific model.
# ZAI_BASE_URL=https://api.z.ai/v1
# ZAI_API_KEY=sk-zai-...
# ZAI_MODEL=glm-4.5-air:free
